# ─────────────────────────────────────────────────────────────────
# HAL OIMS — Backend Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────────────────────────

# Node Environment
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL="postgresql://oims_user:oims_password@localhost:5432/oims_db?schema=public"

# JWT
JWT_SECRET=your-very-long-random-secret-key-minimum-64-characters-here
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=another-long-random-refresh-secret-key-here
JWT_REFRESH_EXPIRES_IN=7d

# CORS — allowed LAN origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://192.168.1.100

# Upload limits
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# Email (SMTP — future use)
SMTP_HOST=smtp.your-org.local
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hal-oims.local

# Application
APP_NAME="HAL OIMS"
APP_URL=http://192.168.1.100

# Logging
LOG_LEVEL=info
LOG_DIR=./logs