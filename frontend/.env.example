# ─────────────────────────────────────────────────────────────────
# HAL OIMS — Frontend Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────────────────────────

# Backend API URL (change to your LAN server IP)
VITE_API_URL=http://192.168.1.100:5000
VITE_SOCKET_URL=http://192.168.1.100:5000

# App metadata
VITE_APP_NAME="HAL OIMS"
VITE_APP_VERSION=1.0.0

# Idle timeout (minutes) — frontend will auto-logout after this
VITE_IDLE_TIMEOUT_MINS=30